---
interface Props {
  title: string;
  description: string;
  tech: string[];
  slug: string;
  status: 'in-progress' | 'complete';
  github?: string;
}
const { title, description, tech, slug, status, github } = Astro.props;
---

<article class="group relative border border-[var(--color-border)] rounded-md p-6 bg-[var(--color-surface)] transition-colors duration-[var(--duration-base)] hover:border-[var(--color-accent)] hover:bg-[var(--color-surface-2)]">
  <!-- Status badge -->
  {status === 'in-progress' && (
    <span class="absolute top-4 right-4 font-mono text-[10px] uppercase tracking-widest text-[var(--color-accent)] opacity-60">
      in progress
    </span>
  )}

  <!-- Title -->
  <h3 class="font-mono text-sm font-medium text-[var(--color-text)] mb-2 group-hover:text-[var(--color-accent)] transition-colors duration-[var(--duration-fast)]">
    <a href={`/work/${slug}`} class="stretched-link before:absolute before:inset-0">
      {title}
    </a>
  </h3>

  <!-- Description -->
  <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-5">
    {description}
  </p>

  <!-- Tech stack -->
  <ul class="flex flex-wrap gap-2">
    {tech.map((t) => (
      <li class="font-mono text-[10px] uppercase tracking-wider px-2 py-1 border border-[var(--color-border)] rounded text-[var(--color-muted)] group-hover:border-[var(--color-accent-dim)] transition-colors duration-[var(--duration-base)]">
        {t}
      </li>
    ))}
  </ul>

  <!-- GitHub link (doesn't trigger the stretched-link) -->
  {github && (
    <a
      href={github}
      target="_blank"
      rel="noopener noreferrer"
      class="relative z-10 inline-flex items-center gap-1.5 mt-4 font-mono text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors duration-[var(--duration-fast)]"
      aria-label={`GitHub repo for ${title}`}
    >
      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
      </svg>
      github
    </a>
  )}
</article>
