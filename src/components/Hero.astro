---
---

<section
  class="relative min-h-[100svh] flex flex-col justify-center px-6 overflow-hidden"
  aria-label="Introduction"
>
  <!-- Blueprint grid background -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="
      background-image:
        linear-gradient(rgba(39,39,45,0.5) 1px, transparent 1px),
        linear-gradient(90deg, rgba(39,39,45,0.5) 1px, transparent 1px);
      background-size: 48px 48px;
      mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 0%, transparent 100%);
    "
  ></div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto w-full" style="animation: fade-up 0.6s ease both 0.1s">
    <!-- Name -->
    <h1 class="font-mono text-5xl sm:text-6xl md:text-7xl font-medium tracking-tight leading-none mb-3">
      Juan Iznardo<span
        class="text-[var(--color-accent)]"
        style="animation: blink 1s step-end infinite"
        aria-hidden="true"
      >_</span>
    </h1>

    <!-- Role -->
    <p class="font-mono text-xs sm:text-sm uppercase tracking-widest text-[var(--color-muted)] mb-8">
      Computer Engineer
    </p>

    <!-- Tagline -->
    <p class="text-lg sm:text-xl md:text-2xl text-[var(--color-muted)] max-w-md leading-relaxed mb-10">
      Computer Engineer based in Spain.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap items-center gap-4">
      <a
        href="#work"
        class="inline-flex items-center gap-2 font-mono text-sm border border-[var(--color-accent)] text-[var(--color-accent)] px-5 py-2.5 rounded hover:bg-[var(--color-accent-dim)] transition-colors duration-[var(--duration-base)]"
      >
        view work
        <span aria-hidden="true">↓</span>
      </a>

      <a
        href="https://github.com/JuanIzn"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-mono text-sm border border-[var(--color-border)] text-[var(--color-muted)] px-5 py-2.5 rounded hover:bg-zinc-850/40 hover:border-zinc-500 hover:text-white hover:shadow-[0_0_15px_rgba(255,255,255,0.06)] transition-all duration-[var(--duration-base)]"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5" aria-hidden="true">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        github
      </a>

      <a
        href="https://www.linkedin.com/in/juan-jes%C3%BAs-iznardo-313429326/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-mono text-sm border border-[var(--color-border)] text-[var(--color-muted)] px-5 py-2.5 rounded hover:bg-[#0a66c2]/10 hover:border-[#0077b5] hover:text-[#00a0dc] hover:shadow-[0_0_15px_rgba(10,102,194,0.15)] transition-all duration-[var(--duration-base)]"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5" aria-hidden="true">
          <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
        </svg>
        linkedin
      </a>
    </div>
  </div>

  <!-- Scroll hint -->
  <div
    class="absolute bottom-8 left-6 max-w-5xl mx-auto"
    style="animation: fade-up 0.6s ease both 0.6s"
    aria-hidden="true"
  >
    <span class="font-mono text-[10px] uppercase tracking-widest text-[var(--color-muted)] opacity-40">
      scroll
    </span>
  </div>
</section>
