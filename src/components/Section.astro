---
interface Props {
  id?: string;
  number?: string;
  label?: string;
  class?: string;
}
const { id, number, label, class: className = '' } = Astro.props;
---

<section
  {id}
  class:list={['py-24 px-6', className]}
>
  {(number || label) && (
    <div class="mb-12">
      <span class="font-mono text-xs uppercase tracking-widest text-[var(--color-muted)]">
        {number && <span class="text-[var(--color-accent)]">{number} — </span>}
        {label}
      </span>
    </div>
  )}
  <slot />
</section>
