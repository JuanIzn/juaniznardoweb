---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Juan Iznardo — Computer Engineer building systems from the ground up.',
  ogImage = '/og.svg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Juan Iznardo" />

    <link rel="me" href="https://github.com/JuanIzn" />
    <link rel="me" href="https://www.linkedin.com/in/juan-jes%C3%BAs-iznardo-313429326/" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Juan Iznardo" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Juan Iznardo",
      "url": "https://juaniznardo.com",
      "jobTitle": "Computer Engineer",
      "description": "Computer Engineering student based in Spain. Building systems from the ground up.",
      "sameAs": [
        "https://github.com/JuanIzn",
        "https://www.linkedin.com/in/juan-jes%C3%BAs-iznardo-313429326/"
      ]
    })} />

    <ClientRouter />
  </head>

  <body class="min-h-screen bg-[var(--color-base)] text-[var(--color-text)]">
    <header
      class="fixed top-0 left-0 right-0 z-50 h-14 flex items-center border-b border-[var(--color-border)] bg-[var(--color-base)]/90 backdrop-blur-sm"
      transition:persist
    >
      <nav class="w-full max-w-5xl mx-auto px-6 flex items-center justify-between">
        <a
          href="/"
          class="font-mono text-sm font-medium text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors duration-[var(--duration-fast)]"
          aria-label="Home"
        >
          ji<span class="text-[var(--color-accent)]">.</span>
        </a>

        <div class="flex items-center gap-6">
          <ul class="flex items-center gap-6 list-none m-0 p-0">
            {[
              { href: '/#work', label: 'work' },
              { href: '/#about', label: 'about' },
              { href: '/#contact', label: 'contact' },
            ].map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="font-mono text-xs text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors duration-[var(--duration-fast)]"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>

          <div class="hidden sm:flex items-center gap-4 border-l border-[var(--color-border)] pl-6">
            <a
              href="https://github.com/JuanIzn"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1.5 font-mono text-xs text-[var(--color-muted)] hover:text-white transition-colors duration-[var(--duration-fast)]"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3" aria-hidden="true">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
              github
            </a>
            <a
              href="https://www.linkedin.com/in/juan-jes%C3%BAs-iznardo-313429326/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1.5 font-mono text-xs text-[var(--color-muted)] hover:text-[#00a0dc] transition-colors duration-[var(--duration-fast)]"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3" aria-hidden="true">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
              linkedin
            </a>
          </div>
        </div>
      </nav>
    </header>

    <main class="pt-14">
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border)] py-8 px-6">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <span class="font-mono text-xs text-[var(--color-muted)]">
          © {new Date().getFullYear()} Juan Iznardo
        </span>

        <div class="flex items-center gap-6">
          <a
            href="https://github.com/JuanIzn"
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors duration-[var(--duration-fast)]"
            aria-label="GitHub"
          >
            github
          </a>
          <a
            href="https://www.linkedin.com/in/juan-jes%C3%BAs-iznardo-313429326/"
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors duration-[var(--duration-fast)]"
            aria-label="LinkedIn"
          >
            linkedin
          </a>
        </div>
      </div>
    </footer>

    <!-- Scroll-triggered fade-in for sections -->
    <script>
      function initScrollAnimations() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                (entry.target as HTMLElement).style.animation = 'fade-up 0.5s ease forwards';
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );

        document.querySelectorAll('[data-animate]').forEach((el) => {
          (el as HTMLElement).style.opacity = '0';
          observer.observe(el);
        });
      }

      initScrollAnimations();
      document.addEventListener('astro:page-load', initScrollAnimations);
    </script>
  </body>
</html>
