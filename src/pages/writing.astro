---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Writing — Juan Iznardo"
  description="Technical writing by Juan Iznardo. Coming soon."
>
  <div class="max-w-3xl mx-auto px-6 py-16 min-h-[60vh] flex flex-col justify-center">
    <a
      href="/"
      class="inline-flex items-center gap-2 font-mono text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors duration-[var(--duration-fast)] mb-16 group"
    >
      <span class="group-hover:-translate-x-1 transition-transform duration-[var(--duration-fast)]">←</span>
      home
    </a>

    <span class="font-mono text-xs uppercase tracking-widest text-[var(--color-muted)] mb-4">
      /writing
    </span>
    <h1 class="font-mono text-2xl font-medium text-[var(--color-text)] mb-4">
      Nothing here yet.
    </h1>
    <p class="text-sm text-[var(--color-muted)] leading-relaxed max-w-sm">
      When there's something worth writing, it'll be here. Until then, the code speaks for itself.
    </p>
  </div>
</Layout>
