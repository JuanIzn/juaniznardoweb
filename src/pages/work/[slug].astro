---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('work');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, tech, github, demo, status } = entry.data;
---

<Layout title={`${title} — Juan Iznardo`} description={description}>
  <article class="max-w-3xl mx-auto px-6 py-16">
    <!-- Back link -->
    <a
      href="/#work"
      class="inline-flex items-center gap-2 font-mono text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors duration-[var(--duration-fast)] mb-12 group"
    >
      <span class="group-hover:-translate-x-1 transition-transform duration-[var(--duration-fast)]">←</span>
      back to work
    </a>

    <!-- Header -->
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="font-mono text-xs uppercase tracking-widest text-[var(--color-muted)]">
          {status === 'in-progress' ? (
            <span class="text-[var(--color-accent)]">in progress</span>
          ) : (
            <span>complete</span>
          )}
        </span>
      </div>

      <h1 class="font-mono text-3xl sm:text-4xl font-medium mb-4">
        {title}
      </h1>

      <p class="text-[var(--color-muted)] text-lg leading-relaxed mb-6">
        {description}
      </p>

      <!-- Tech + links -->
      <div class="flex flex-wrap items-center gap-3">
        {tech.map((t) => (
          <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-1 border border-[var(--color-border)] rounded text-[var(--color-muted)]">
            {t}
          </span>
        ))}

        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="ml-auto font-mono text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors duration-[var(--duration-fast)] flex items-center gap-1.5"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            github
          </a>
        )}

        {demo && (
          <a
            href={demo}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors duration-[var(--duration-fast)]"
          >
            live demo ↗
          </a>
        )}
      </div>
    </header>

    <!-- Divider -->
    <div class="border-t border-[var(--color-border)] mb-12"></div>

    <!-- MDX content -->
    <div class="prose prose-sm prose-invert max-w-none
      prose-headings:font-mono prose-headings:font-medium prose-headings:text-[var(--color-text)]
      prose-h2:text-sm prose-h2:uppercase prose-h2:tracking-widest prose-h2:text-[var(--color-muted)] prose-h2:mt-10 prose-h2:mb-4
      prose-p:text-[var(--color-muted)] prose-p:leading-relaxed
      prose-strong:text-[var(--color-text)] prose-strong:font-medium
      prose-code:font-mono prose-code:text-[var(--color-accent)] prose-code:text-xs prose-code:bg-[var(--color-surface)] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
      prose-a:text-[var(--color-accent)] prose-a:no-underline hover:prose-a:underline
      prose-li:text-[var(--color-muted)]
    ">
      <Content />
    </div>
  </article>
</Layout>
